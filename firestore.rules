rules_version = '2';

// Complete Firestore ruleset for every private harsh.bet app in the shared
// `pickledgerpro` Firebase project. Deploying one rules file replaces the
// project rules, so this file must be kept identical on Daymark, Slate, Fare,
// and Sift branches whenever any block changes.

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthorizedGoogleAccount() {
      return request.auth != null
        && request.auth.token.email == 'hdav4873@gmail.com'
        && request.auth.token.email_verified == true
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    // Daymark (habit tracker) ---------------------------------------
    function ownsDaymarkData(userId) {
      return isAuthorizedGoogleAccount() && request.auth.uid == userId;
    }

    function hasConsistentGeneration() {
      return request.resource.data.generationId is string
        && request.resource.data.profileGenerationId == request.resource.data.generationId;
    }

    match /daymark_users/{userId} {
      allow read: if ownsDaymarkData(userId);
      allow create, update: if ownsDaymarkData(userId) && hasConsistentGeneration();

      match /habits/{habitId} {
        allow read, write: if ownsDaymarkData(userId);
      }

      match /entries/{entryId} {
        allow read, write: if ownsDaymarkData(userId);
      }
    }

    // Slate (schedule + to-do) -------------------------------------
    function ownsSlateData(userId) {
      return isAuthorizedGoogleAccount() && request.auth.uid == userId;
    }

    match /slate_users/{userId} {
      allow read: if ownsSlateData(userId);
      allow create, update: if ownsSlateData(userId)
        && request.resource.data.schemaVersion == 1;

      match /sections/{sectionId} {
        allow read, write: if ownsSlateData(userId);
      }

      match /tasks/{taskId} {
        allow read, write: if ownsSlateData(userId);
      }

      match /blocks/{blockId} {
        allow read, write: if ownsSlateData(userId);
      }
    }

    // Fare (calorie + nutrition tracker) ---------------------------
    function ownsFareData(userId) {
      return isAuthorizedGoogleAccount() && request.auth.uid == userId;
    }

    function isValidFareSingleton(documentId) {
      return documentId == 'current'
        && request.resource.data.updatedAt is string;
    }

    function isValidFareEntity(entityId) {
      return request.resource.data.id == entityId
        && request.resource.data.updatedAt is string
        && (
          (!('deleted' in request.resource.data) && !('deletedAt' in request.resource.data))
          || (request.resource.data.deleted == true && request.resource.data.deletedAt is string)
        );
    }

    function keepsFareTombstone() {
      return !('deleted' in resource.data)
        || resource.data.deleted != true
        || (('deleted' in request.resource.data) && request.resource.data.deleted == true);
    }

    match /fare_users/{userId} {
      // Fare has no root document. Explicit subcollection rules below are
      // intentionally the only access path.
      match /profile/{documentId} {
        allow read: if ownsFareData(userId) && documentId == 'current';
        allow create, update: if ownsFareData(userId) && isValidFareSingleton(documentId);
      }

      match /targets/{documentId} {
        allow read: if ownsFareData(userId) && documentId == 'current';
        allow create, update: if ownsFareData(userId) && isValidFareSingleton(documentId);
      }

      match /settings/{documentId} {
        allow read: if ownsFareData(userId) && documentId == 'current';
        allow create, update: if ownsFareData(userId) && isValidFareSingleton(documentId);
      }

      match /foods/{foodId} {
        allow read: if ownsFareData(userId);
        allow create: if ownsFareData(userId) && isValidFareEntity(foodId);
        allow update: if ownsFareData(userId) && isValidFareEntity(foodId) && keepsFareTombstone();
      }

      match /meals/{mealId} {
        allow read: if ownsFareData(userId);
        allow create: if ownsFareData(userId) && isValidFareEntity(mealId);
        allow update: if ownsFareData(userId) && isValidFareEntity(mealId) && keepsFareTombstone();
      }

      match /entries/{entryId} {
        allow read: if ownsFareData(userId);
        allow create: if ownsFareData(userId) && isValidFareEntity(entryId);
        allow update: if ownsFareData(userId) && isValidFareEntity(entryId) && keepsFareTombstone();
      }
    }

    // Sift (research paper workspace) -------------------------------
    function ownsResearchData(userId) {
      return isAuthorizedGoogleAccount() && request.auth.uid == userId;
    }

    function isValidResearchTombstone() {
      return (
        !('deleted' in request.resource.data)
        && !('deletedAt' in request.resource.data)
      ) || (
        request.resource.data.deleted == true
        && ('deletedAt' in request.resource.data)
        && request.resource.data.deletedAt is string
      );
    }

    function advancesResearchSingleton() {
      return request.resource.data.updatedAt >= resource.data.updatedAt;
    }

    function isValidResearchEntity(entityId) {
      return request.resource.data.id == entityId
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && isValidResearchTombstone();
    }

    function keepsResearchEntityHistory() {
      return request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt >= resource.data.updatedAt
        && (
          !('deleted' in resource.data)
          || resource.data.deleted != true
          || (('deleted' in request.resource.data) && request.resource.data.deleted == true)
        );
    }

    function isValidResearchProfile(documentId) {
      return documentId == 'current'
        && request.resource.data.keys().hasAll([
          'email', 'displayName', 'onboardingComplete', 'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'email', 'displayName', 'photoURL', 'onboardingComplete', 'updatedAt'
        ])
        && request.resource.data.email == 'hdav4873@gmail.com'
        && request.resource.data.displayName is string
        && request.resource.data.onboardingComplete is bool
        && request.resource.data.updatedAt is string
        && (!('photoURL' in request.resource.data) || request.resource.data.photoURL is string);
    }

    function isValidResearchSettings(documentId) {
      return documentId == 'current'
        && request.resource.data.keys().hasAll([
          'theme', 'readerWidth', 'defaultZoom', 'autoAnalyze', 'rememberChat', 'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'theme', 'readerWidth', 'defaultZoom', 'autoAnalyze', 'rememberChat', 'updatedAt'
        ])
        && request.resource.data.theme in ['system', 'light', 'dark']
        && request.resource.data.readerWidth in ['comfortable', 'wide', 'full']
        && request.resource.data.defaultZoom is number
        && request.resource.data.defaultZoom >= 0.5
        && request.resource.data.defaultZoom <= 4
        && request.resource.data.autoAnalyze is bool
        && request.resource.data.rememberChat is bool
        && request.resource.data.updatedAt is string;
    }

    function isValidResearchFile(paperId) {
      return request.resource.data.file is map
        && request.resource.data.file.keys().hasAll([
          'storageKey', 'name', 'sizeBytes', 'mimeType'
        ])
        && request.resource.data.file.keys().hasOnly([
          'storageKey', 'name', 'sizeBytes', 'mimeType', 'sha256'
        ])
        && request.resource.data.file.storageKey == paperId
        && request.resource.data.file.name is string
        && request.resource.data.file.sizeBytes is int
        && request.resource.data.file.sizeBytes > 0
        && request.resource.data.file.sizeBytes <= 52428800
        && request.resource.data.file.mimeType == 'application/pdf'
        && (!('sha256' in request.resource.data.file) || (
          request.resource.data.file.sha256 is string
          && request.resource.data.file.sha256.matches('^[A-Fa-f0-9]{64}$')
        ));
    }

    function isValidResearchAnalysisLease() {
      return !('analysisLease' in request.resource.data) || (
        request.resource.data.analysisLease is map
        && request.resource.data.analysisLease.keys().hasAll([
          'runId', 'ownerId', 'mode', 'heartbeatAt'
        ])
        && request.resource.data.analysisLease.keys().hasOnly([
          'runId', 'ownerId', 'mode', 'heartbeatAt'
        ])
        && request.resource.data.analysisLease.runId is string
        && request.resource.data.analysisLease.runId.size() > 0
        && request.resource.data.analysisLease.runId.size() <= 240
        && request.resource.data.analysisLease.runId.matches('^[A-Za-z0-9][A-Za-z0-9._:-]*$')
        && request.resource.data.analysisLease.ownerId is string
        && request.resource.data.analysisLease.ownerId.size() > 0
        && request.resource.data.analysisLease.ownerId.size() <= 240
        && request.resource.data.analysisLease.ownerId.matches('^[A-Za-z0-9][A-Za-z0-9._:-]*$')
        && request.resource.data.analysisLease.mode in ['local', 'ai']
        && request.resource.data.analysisLease.heartbeatAt is string
        && request.resource.data.analysisLease.heartbeatAt.size() > 0
        && request.resource.data.analysisLease.heartbeatAt.size() <= 64
        && request.resource.data.analysisLease.heartbeatAt.matches(
          '^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]([.][0-9]{1,9})?Z$'
        )
      );
    }

    function changesResearchAnalysisState() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'analysisStatus', 'analysisProgress', 'analysisError', 'analysisModel',
        'analysisCompletedAt', 'analysisLease', 'openaiFileId', 'summary',
        'analysisUpdatedAt', 'analysisRunId'
      ]);
    }

    function protectsResearchAnalysisState() {
      return (
        ('analysisUpdatedAt' in resource.data)
        && ('analysisUpdatedAt' in request.resource.data)
        && request.resource.data.analysisUpdatedAt >= resource.data.analysisUpdatedAt
        && (
          request.resource.data.analysisUpdatedAt > resource.data.analysisUpdatedAt
          || !changesResearchAnalysisState()
        )
      ) || (
        !('analysisUpdatedAt' in resource.data)
        && (
          !('analysisLease' in resource.data)
          || !changesResearchAnalysisState()
          || ('analysisUpdatedAt' in request.resource.data)
        )
      );
    }

    function isValidResearchPaper(paperId) {
      return isValidResearchEntity(paperId)
        && request.resource.data.keys().hasAll([
          'id', 'createdAt', 'updatedAt', 'title', 'authors', 'file', 'tags',
          'favorite', 'archived', 'analysisStatus'
        ])
        && request.resource.data.keys().hasOnly([
          'id', 'createdAt', 'updatedAt', 'deleted', 'deletedAt', 'title',
          'authors', 'year', 'venue', 'doi', 'sourceUrl', 'abstract',
          'pageCount', 'file', 'tags', 'favorite', 'archived', 'lastOpenedAt',
          'analysisStatus', 'analysisProgress', 'analysisError', 'analysisModel',
          'analysisCompletedAt', 'analysisUpdatedAt', 'analysisRunId', 'analysisLease',
          'openaiFileId', 'summary'
        ])
        && request.resource.data.title is string
        && request.resource.data.authors is list
        && request.resource.data.tags is list
        && request.resource.data.favorite is bool
        && request.resource.data.archived is bool
        && request.resource.data.analysisStatus in [
          'local', 'queued', 'uploading', 'analyzing', 'ready', 'error'
        ]
        && (!('year' in request.resource.data) || request.resource.data.year is int)
        && (!('venue' in request.resource.data) || request.resource.data.venue is string)
        && (!('doi' in request.resource.data) || request.resource.data.doi is string)
        && (!('sourceUrl' in request.resource.data) || request.resource.data.sourceUrl is string)
        && (!('abstract' in request.resource.data) || request.resource.data.abstract is string)
        && (!('pageCount' in request.resource.data) || request.resource.data.pageCount is int)
        && (!('analysisProgress' in request.resource.data) || request.resource.data.analysisProgress is number)
        && (!('analysisProgress' in request.resource.data) || request.resource.data.analysisProgress >= 0)
        && (!('analysisProgress' in request.resource.data) || request.resource.data.analysisProgress <= 100)
        && (!('analysisError' in request.resource.data) || request.resource.data.analysisError is string)
        && (!('analysisModel' in request.resource.data) || request.resource.data.analysisModel is string)
        && (!('analysisCompletedAt' in request.resource.data) || request.resource.data.analysisCompletedAt is string)
        && (!('analysisUpdatedAt' in request.resource.data) || (
          request.resource.data.analysisUpdatedAt is string
          && request.resource.data.analysisUpdatedAt.size() > 0
          && request.resource.data.analysisUpdatedAt.size() <= 64
          && request.resource.data.analysisUpdatedAt.matches(
            '^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]([.][0-9]{1,9})?Z$'
          )
        ))
        && (!('analysisRunId' in request.resource.data) || (
          request.resource.data.analysisRunId is string
          && request.resource.data.analysisRunId.size() > 0
          && request.resource.data.analysisRunId.size() <= 240
          && request.resource.data.analysisRunId.matches('^[A-Za-z0-9][A-Za-z0-9._:-]*$')
        ))
        && (!('openaiFileId' in request.resource.data) || request.resource.data.openaiFileId is string)
        && (!('lastOpenedAt' in request.resource.data) || request.resource.data.lastOpenedAt is string)
        && (!('summary' in request.resource.data) || request.resource.data.summary is map)
        && isValidResearchAnalysisLease()
        && isValidResearchFile(paperId);
    }

    function isValidResearchNote(noteId) {
      return isValidResearchEntity(noteId)
        && request.resource.data.keys().hasAll([
          'id', 'createdAt', 'updatedAt', 'paperId', 'body', 'color'
        ])
        && request.resource.data.keys().hasOnly([
          'id', 'createdAt', 'updatedAt', 'deleted', 'deletedAt', 'paperId',
          'page', 'section', 'body', 'color'
        ])
        && request.resource.data.paperId is string
        && request.resource.data.body is string
        && request.resource.data.color in ['amber', 'blue', 'green', 'rose']
        && (!('page' in request.resource.data) || request.resource.data.page is int)
        && (!('section' in request.resource.data) || request.resource.data.section is string);
    }

    function isValidResearchMessage(messageId) {
      return isValidResearchEntity(messageId)
        && request.resource.data.keys().hasAll([
          'id', 'createdAt', 'updatedAt', 'paperId', 'role', 'content',
          'context', 'citations'
        ])
        && request.resource.data.keys().hasOnly([
          'id', 'createdAt', 'updatedAt', 'deleted', 'deletedAt', 'paperId',
          'role', 'content', 'context', 'citations', 'grounded',
          'uncertainty', 'responseId', 'model'
        ])
        && request.resource.data.paperId is string
        && request.resource.data.role in ['user', 'assistant']
        && request.resource.data.content is string
        && request.resource.data.context is map
        && request.resource.data.context.keys().hasAll(['tab'])
        && request.resource.data.context.keys().hasOnly([
          'tab', 'page', 'section', 'selectedText'
        ])
        && request.resource.data.context.tab in [
          'brief', 'sections', 'visuals', 'equations', 'ledger', 'notes', 'sources'
        ]
        && (!('page' in request.resource.data.context) || request.resource.data.context.page is int)
        && (!('section' in request.resource.data.context) || request.resource.data.context.section is string)
        && (!('selectedText' in request.resource.data.context) || request.resource.data.context.selectedText is string)
        && request.resource.data.citations is list
        && (!('grounded' in request.resource.data) || request.resource.data.grounded is bool)
        && (!('uncertainty' in request.resource.data) || request.resource.data.uncertainty is string)
        && (!('responseId' in request.resource.data) || request.resource.data.responseId is string)
        && (!('model' in request.resource.data) || request.resource.data.model is string);
    }

    match /research_users/{userId} {
      // Sift has no readable root document and never stores original PDF bytes.
      match /profile/{documentId} {
        allow read: if ownsResearchData(userId) && documentId == 'current';
        allow create: if ownsResearchData(userId) && isValidResearchProfile(documentId);
        allow update: if ownsResearchData(userId)
          && isValidResearchProfile(documentId)
          && advancesResearchSingleton();
      }

      match /settings/{documentId} {
        allow read: if ownsResearchData(userId) && documentId == 'current';
        allow create: if ownsResearchData(userId) && isValidResearchSettings(documentId);
        allow update: if ownsResearchData(userId)
          && isValidResearchSettings(documentId)
          && advancesResearchSingleton();
      }

      match /papers/{paperId} {
        allow read: if ownsResearchData(userId);
        allow create: if ownsResearchData(userId) && isValidResearchPaper(paperId);
        allow update: if ownsResearchData(userId)
          && isValidResearchPaper(paperId)
          && keepsResearchEntityHistory()
          && protectsResearchAnalysisState();
      }

      match /notes/{noteId} {
        allow read: if ownsResearchData(userId);
        allow create: if ownsResearchData(userId) && isValidResearchNote(noteId);
        allow update: if ownsResearchData(userId)
          && isValidResearchNote(noteId)
          && keepsResearchEntityHistory();
      }

      match /messages/{messageId} {
        allow read: if ownsResearchData(userId);
        allow create: if ownsResearchData(userId) && isValidResearchMessage(messageId);
        allow update: if ownsResearchData(userId)
          && isValidResearchMessage(messageId)
          && keepsResearchEntityHistory();
      }
    }

    // Notes (private synced notes) ---------------------------------
    function ownsNotesData(userId) {
      return isAuthorizedGoogleAccount() && request.auth.uid == userId;
    }

    function isValidNotesId(value) {
      return value is string
        && value.size() > 0
        && value.size() <= 128
        && value.matches('^[A-Za-z0-9_-]+$');
    }

    function isValidNotesLabelAt(labels, index) {
      return labels.size() <= index || (
        labels[index] is string
        && labels[index].size() > 0
        && labels[index].size() <= 48
        && labels[index].matches('.*\\S.*')
      );
    }

    function isValidNotesLabels(labels) {
      return labels is list
        && labels.size() <= 12
        && labels.toSet().size() == labels.size()
        && isValidNotesLabelAt(labels, 0)
        && isValidNotesLabelAt(labels, 1)
        && isValidNotesLabelAt(labels, 2)
        && isValidNotesLabelAt(labels, 3)
        && isValidNotesLabelAt(labels, 4)
        && isValidNotesLabelAt(labels, 5)
        && isValidNotesLabelAt(labels, 6)
        && isValidNotesLabelAt(labels, 7)
        && isValidNotesLabelAt(labels, 8)
        && isValidNotesLabelAt(labels, 9)
        && isValidNotesLabelAt(labels, 10)
        && isValidNotesLabelAt(labels, 11);
    }

    function hasNotesCreateTimestamps() {
      return request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function hasNotesUpdateTimestamps() {
      return request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
    }

    function isTrashedNotesTombstone(noteData) {
      return ('deleted' in noteData)
        && noteData.deleted == true
        && ('deletedAt' in noteData)
        && noteData.deletedAt is timestamp;
    }

    // Notes uses a recoverable trash. A note is either untrashed (neither
    // tombstone field present) or trashed (deleted == true with a timestamp).
    // Restoring removes both fields again, so a restored note is byte-shaped
    // exactly like one that was never trashed.
    function isValidNotesTombstone(noteData) {
      return (
        !('deleted' in noteData)
        && !('deletedAt' in noteData)
      ) || isTrashedNotesTombstone(noteData);
    }

    function isValidNotesNote(noteData, noteId) {
      return noteData.keys().hasAll([
          'id', 'title', 'content', 'contentText', 'richBackup', 'format',
          'folderId', 'labels', 'pinned', 'revision', 'createdAt', 'updatedAt'
        ])
        && noteData.keys().hasOnly([
          'id', 'title', 'content', 'contentText', 'richBackup', 'format',
          'folderId', 'labels', 'pinned', 'revision', 'createdAt', 'updatedAt',
          'deleted', 'deletedAt'
        ])
        && isValidNotesTombstone(noteData)
        && noteData.id == noteId
        && isValidNotesId(noteData.id)
        && noteData.title is string
        && noteData.title.size() <= 240
        && noteData.content is string
        && noteData.content.size() <= 600000
        && noteData.contentText is string
        && noteData.contentText.size() <= 200000
        && noteData.richBackup is string
        && noteData.richBackup.size() <= 600000
        && noteData.content.size()
          + noteData.contentText.size()
          + noteData.richBackup.size() <= 850000
        && noteData.format in ['rich', 'plain']
        && noteData.folderId is string
        && noteData.folderId.size() <= 128
        && (
          noteData.folderId.size() == 0
          || isValidNotesId(noteData.folderId)
        )
        && isValidNotesLabels(noteData.labels)
        && noteData.pinned is bool
        && noteData.revision is int
        && noteData.revision >= 0
        && noteData.revision <= 2147483647;
    }

    function hasNotesCreateRevision() {
      return request.resource.data.revision == 0;
    }

    function hasNotesUpdateRevision() {
      return resource.data.revision is int
        && request.resource.data.revision == resource.data.revision + 1;
    }

    function isValidNotesFolder(folderId) {
      return request.resource.data.keys().hasAll([
          'id', 'name', 'color', 'order', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'id', 'name', 'color', 'order', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.id == folderId
        && isValidNotesId(request.resource.data.id)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.name.matches('.*\\S.*')
        && request.resource.data.color is string
        && request.resource.data.color.size() > 0
        && request.resource.data.color.size() <= 32
        && request.resource.data.color.matches(
          '^(#[A-Fa-f0-9]{6}|[a-z][a-z0-9-]{0,31})$'
        )
        && request.resource.data.order is int
        && request.resource.data.order >= 0
        && request.resource.data.order <= 10000;
    }

    function isValidNotesSettings(documentId) {
      return documentId == 'current'
        && request.resource.data.keys().hasAll([
          'theme', 'smartFormatting', 'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'theme', 'smartFormatting', 'updatedAt'
        ])
        && request.resource.data.theme in ['system', 'light', 'dark']
        && request.resource.data.smartFormatting is bool
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time;
    }

    match /notes_users/{userId} {
      // Notes has no root document. Only these explicit, owner-scoped
      // subcollections are readable or writable.
      match /notes/{noteId} {
        allow read: if ownsNotesData(userId);
        allow create: if ownsNotesData(userId)
          && isValidNotesNote(request.resource.data, noteId)
          && hasNotesCreateRevision()
          && hasNotesCreateTimestamps();
        allow update: if ownsNotesData(userId)
          && isValidNotesNote(request.resource.data, noteId)
          && hasNotesUpdateRevision()
          && hasNotesUpdateTimestamps();
        // Permanent deletion is an explicit second step from Trash. Live or
        // malformed notes cannot skip the tombstone transition.
        allow delete: if ownsNotesData(userId)
          && isValidNotesNote(resource.data, noteId)
          && isTrashedNotesTombstone(resource.data);
      }

      match /folders/{folderId} {
        allow read: if ownsNotesData(userId);
        allow create: if ownsNotesData(userId)
          && isValidNotesFolder(folderId)
          && hasNotesCreateTimestamps();
        allow update: if ownsNotesData(userId)
          && isValidNotesFolder(folderId)
          && hasNotesUpdateTimestamps();
      }

      match /settings/{documentId} {
        allow read: if ownsNotesData(userId) && documentId == 'current';
        allow create, update: if ownsNotesData(userId)
          && isValidNotesSettings(documentId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
